// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: Firebase UID
// Fields:
//   - email: string (required)
//   - username: string (required)
//   - role: string (ADMIN, EMPLOYEE)
//   - createdAt: string
//
// Collection: businesses
// Fields:
//   - name: string (required)
//   - name_lowercase: string
//   - postcode: string (required)
//   - postcode_lowercase: string
//   - ownerName: string
//   - telephone: string
//   - contactNumber: string
//   - email: string
//   - address: string
//   - createdAt: string
//   - updatedAt: timestamp
//
// Collection: installationRecords (Installation Records)
// Fields:
//   - businessId: string (required)
//   - invoiceNumber: string
//   - installationDate: string
//   - supportType: string
//   - supportStatus: string
//   - supportStartDate: string
//   - supportEndDate: string
//   - equipment: list
//   - paymentAmount: number
//   - paymentStatus: string
//   - paymentDueAmount: number
//   - salesPerson: string
//   - engineer: string
//   - softwareType: string
//   - licenseNumbers: list
//   - teamViewerIds: list
//   - comments: string
//
// Collection: logs
// Fields:
//   - userId: string
//   - username: string
//   - action: string
//   - timestamp: string
//
// Collection: equipmentTypes, salesPeople, engineers, softwareTypes
// Fields:
//   - name: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "pasi@tillmax.co.uk" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    function isEmployee() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'EMPLOYEE')
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile, Admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Admins can create any profile; users can create their own (needed for initial setup)
      allow create: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow update, delete: if isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if isAuthenticated();
      allow create, update: if isEmployee() && 
        request.resource.data.name is string && request.resource.data.name.size() < 200 &&
        request.resource.data.postcode is string && request.resource.data.postcode.size() < 20;
      allow delete: if isAdmin();
    }

    match /installationRecords/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isEmployee() &&
        request.resource.data.businessId is string &&
        (!('invoiceNumber' in request.resource.data) || request.resource.data.invoiceNumber.size() < 100);
      allow update: if isEmployee() &&
        request.resource.data.businessId == resource.data.businessId &&
        (!('invoiceNumber' in request.resource.data) || request.resource.data.invoiceNumber.size() < 100) &&
        (!('comments' in request.resource.data) || request.resource.data.comments is string && request.resource.data.comments.size() < 5000);
      allow delete: if isAdmin();
    }

    match /instructionRecords/{recordId} {
      allow read, delete: if isAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read, write: if isAdmin();
    }

    match /systemSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.action is string && request.resource.data.action.size() < 500;
    }

    match /equipmentTypes/{id} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isEmployee();
    }

    match /stockMovements/{id} {
      allow read: if isAuthenticated();
      allow create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    match /categories/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /suppliers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /salesPeople/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /engineers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /softwareTypes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
